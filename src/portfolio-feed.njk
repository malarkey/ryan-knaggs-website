---
title: "Portfolio projects"
summary: "Recent portfolio work by Ryan Knaggs."
permalink: "/portfolio/feed.xml"
---
<?xml version="1.0" encoding="utf-8"?>
{% set siteBaseUrl = site.absoluteUrl or site.url or "" %}
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.name }} {{ title }}</title>
  <subtitle>{{ summary }}</subtitle>
  <link href="{{ siteBaseUrl }}{{ permalink }}" rel="self"/>
  <link href="{{ siteBaseUrl }}/portfolio/"/>
  <updated>{{ collections.portfolioItems | rssLastUpdatedDate }}</updated>
  <id>{{ siteBaseUrl }}/portfolio/</id>
  <author>
    <name>{{ site.authorName }}</name>
    <email>{{ site.authorEmail }}</email>
  </author>
  {% for item in collections.portfolioItems %}
    {% set absoluteItemUrl %}{{ siteBaseUrl }}{{ item.url | url }}{% endset %}
    <entry>
      <title>{{ item.data.title }}</title>
      <link href="{{ absoluteItemUrl }}"/>
      <updated>{{ (item.data.date or item.date) | rssDate }}</updated>
      <id>{{ absoluteItemUrl }}</id>
      <content type="html"><![CDATA[
        {{ item.templateContent | safe }}
      ]]></content>
    </entry>
  {% endfor %}
</feed>
